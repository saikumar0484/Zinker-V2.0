{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Google Drive and sync settings",
      "type": "object",
      "properties": {
        "google_client_id": { "type": "string" },
        "google_client_secret": { "type": "string" },
        "google_redirect_uri": { "type": "string" },
        "google_refresh_token": { "type": "string" },
        "drive_parent_folder_id": { "type": "string" },
        "drive_verified": { "type": "boolean" },
        "polling_interval": { "type": "integer" },
        "last_sync_at": { "type": "string", "format": "date-time" }
      }
    },
    "ZoomAccount": {
      "title": "ZoomAccount",
      "description": "Zoom account credentials",
      "type": "object",
      "properties": {
        "account_name": { "type": "string" },
        "zoom_account_id": { "type": "string" },
        "zoom_client_id": { "type": "string" },
        "zoom_client_secret": { "type": "string" },
        "zoom_verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["account_name", "zoom_account_id", "zoom_client_id", "zoom_client_secret"]
    },
    "Recording": {
      "title": "Recording",
      "description": "Zoom recording sync status",
      "type": "object",
      "properties": {
        "zoom_account_id": { "type": "string" },
        "meeting_id": { "type": "string" },
        "uuid": { "type": "string" },
        "meeting_name": { "type": "string" },
        "start_time": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PENDING", "PROCESSING", "COMPLETED", "FAILED"] },
        "drive_folder_link": { "type": "string" },
        "files_uploaded": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["meeting_id", "uuid", "meeting_name", "start_time", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User document"
    },
    "/users/{userId}/settings/config": {
      "schema": "Settings",
      "description": "User settings"
    },
    "/users/{userId}/zoom_accounts/{accountId}": {
      "schema": "ZoomAccount",
      "description": "User Zoom accounts"
    },
    "/users/{userId}/recordings/{recordingId}": {
      "schema": "Recording",
      "description": "User recordings"
    }
  }
}
